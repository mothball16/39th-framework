{
  "name": "Pearhead",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "Packages": {
        "$ignoreUnknownInstances": false,
        "$path": "Packages"
      },
      "DevPackages": {
        "$ignoreUnknownInstances": false,
        "$path": "DevPackages"
      },
      "Utility": {
        "$ignoreUnknownInstances": false,
        "$path":"Utility"
      },
      "SPH_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/ReplicatedStorage/SPH_Framework"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "SPH_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/ServerScriptService/SPH_Server"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$ignoreUnknownInstances": true,
      "StarterCharacterScripts": {
        "$className": "StarterCharacterScripts",
        "$ignoreUnknownInstances": true,
        "SPH_Character":{
          "$ignoreUnknownInstances": false,
          "$path": "src/StarterPlayer/StarterCharacterScripts/SPH_Character"
        }
      },
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "SPH_Player":{
          "$ignoreUnknownInstances": false,
          "$path": "src/StarterPlayer/StarterPlayerScripts/SPH_Player"
        }
      }
    }
  }
}