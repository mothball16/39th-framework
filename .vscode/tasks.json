{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Update Wally & Sourcemap",
      "type": "shell",
      "windows": {
        "command": "powershell -NoProfile -File scripts/update-packages.ps1"
      },
      "linux": {
        "command": "bash scripts/update-packages.sh"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Format with StyLua",
      "type": "shell",
      "command": "stylua src/",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
