{
  "name": "all-in-one",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "$path": "src/ReplicatedStorage",
      "Packages": {
        "$path": "Packages"
      },

      "DevPackages": {
        "$path": "DevPackages"
      },

      "Utility": {
        "$path":"Utility"
      },

      "Class_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/_Systems/ClassSystem/Class_Framework"
      },

      "SPH_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/_Systems/WeaponSystem/SPH_Framework"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "$path": "src/ServerScriptService",

      "Class_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/_Systems/ClassSystem/Class_Server"
      },

      "SPH_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/_Systems/WeaponSystem/SPH_Server"
      },

      "Class_RadioMod": {
        "$ignoreUnknownInstances": false,
        "$path": "src/_Systems/Class_RadioMod"
      }

    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$ignoreUnknownInstances": true,
      "StarterCharacterScripts": {
        "$className": "StarterCharacterScripts",
        "$ignoreUnknownInstances": true,
        "$path": "src/StarterPlayer/StarterCharacterScripts",

        "SPH_Character": {
          "$ignoreUnknownInstances": false,
          "$path": "src/_Systems/WeaponSystem/SPH_Character"
        }
      },

      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "$path": "src/StarterPlayer/StarterPlayerScripts",

        "Class_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/_Systems/ClassSystem/Class_Player"
        },

        "SPH_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/_Systems/WeaponSystem/SPH_Player"
        }
      }

      
    }
  }
}