{
  "name": "all-in-one",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "$path": "src/ReplicatedStorage",
      "Packages": {
        "$ignoreUnknownInstances": false,
        "$path": "Packages"
      },

      "DevPackages": {
        "$ignoreUnknownInstances": false,
        "$path": "DevPackages"
      },

      "Utility": {
        "$ignoreUnknownInstances": false,
        "$path":"src/Utility"
      },

      "Synced": {
        "$ignoreUnknownInstances": false,
        "$path": "src/General/Shared"
      },

      "Faction_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/FactionSystem/Framework"
      },

      "Aware_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/AwareSystem/Framework"
      },

      "Aware_FactionMod": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/Aware_FactionMod/Shared"
      },

      "SPH_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/WeaponSystem/Framework"
      },

      "Radio_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/RadioSystem/Framework"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,

      "Synced": {
        "$ignoreUnknownInstances": false,
        "$path": "src/General/Server"
      },

      "Faction_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/FactionSystem/Server"
      },

      "SPH_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/WeaponSystem/Server"
      },

      "Aware_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/AwareSystem/Server"
      },

      "Aware_FactionMod": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/Aware_FactionMod/Server"
      },

      "Radio_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/RadioSystem/Server"
      },

      "StateSync_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/StateSync/Server"
      }

    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$ignoreUnknownInstances": true,
      
      "StarterCharacterScripts": {
        "$className": "StarterCharacterScripts",
        "$ignoreUnknownInstances": true,

        "SPH_Character": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/WeaponSystem/Character"
        }
      },

      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        
        "Synced": {
          "$ignoreUnknownInstances": false,
          "$path": "src/General/Client"
        },

        "Faction_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/FactionSystem/Player"
        },

        "SPH_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/WeaponSystem/Player"
        },

        "Aware_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/AwareSystem/Player"
        },

        "Radio_Client": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/RadioSystem/Client"
        },

        "StateSync_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/StateSync/Player"
        }
      }

      
    }
