{
  "name": "all-in-one",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "$path": "src/ReplicatedStorage",
      "Packages": {
        "$ignoreUnknownInstances": false,
        "$path": "Packages"
      },
      "DevPackages": {
        "$ignoreUnknownInstances": false,
        "$path": "DevPackages"
      },
      "Utility": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Utility"
      },
      "Systems": {
        "$className": "Folder",
        "$ignoreUnknownInstances": false,
        "Faction": {
          "$path": "src/Systems/Faction/Framework"
        },
        "Aware": {
          "$path": "src/Systems/Aware/Framework"
        },
        "Aware_FactionMod": {
          "$path": "src/Systems/Aware_FactionMod/Shared"
        },
        "Weapon": {
          "$path": "src/Systems/Weapon/Framework"
        },
        "Radio": {
          "$path": "src/Systems/Radio/Framework"
        }
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Systems": {
        "$className": "Folder",
        "$ignoreUnknownInstances": false,
        "Faction": {
          "$path": "src/Systems/Faction/Server"
        },
        "Weapon": {
          "$path": "src/Systems/Weapon/Server"
        },
        "Aware": {
          "$path": "src/Systems/Aware/Server"
        },
        "Aware_FactionMod": {
          "$path": "src/Systems/Aware_FactionMod/Server"
        },
        "Radio": {
          "$path": "src/Systems/Radio/Server"
        },
        "General": {
          "$path": "src/Systems/General/Server"
        },
        "StateSync": {
          "$path": "src/Systems/StateSync/Server"
        }
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterCharacterScripts": {
        "$className": "StarterCharacterScripts",
        "Systems": {
          "$className": "Folder",
          "$ignoreUnknownInstances": false,
          "Weapon": {
            "$path": "src/Systems/Weapon/Character"
          }
        }
      },
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "Systems": {
          "$className": "Folder",
          "$ignoreUnknownInstances": false,
          "Faction": {
            "$path": "src/Systems/Faction/Player"
          },
          "Weapon": {
            "$path": "src/Systems/Weapon/Player"
          },
          "Aware": {
            "$path": "src/Systems/Aware/Player"
          },
          "Radio": {
            "$path": "src/Systems/Radio/Client"
          },
          "General": {
            "$path": "src/Systems/General/Client"
          },
          "StateSync": {
            "$path": "src/Systems/StateSync/Player"
          }
        }
      }
    }
  }
}
