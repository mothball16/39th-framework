      "$ignoreUnknownInstances": true,
      "$path": "src/ReplicatedStorage",
      "Packages": {
        "$path": "Packages"
      },

      "DevPackages": {
        "$path": "DevPackages"
      },

      "Utility": {
        "$path":"Utility"
      },

      "Class_Framework": {
        "$ignoreUnknownInstances": false,
