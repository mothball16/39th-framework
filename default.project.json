      "$ignoreUnknownInstances": true,
      "$path": "src/ReplicatedStorage",
      "Packages": {
        "$ignoreUnknownInstances": false,
        "$path": "Packages"
      },

      "DevPackages": {
        "$ignoreUnknownInstances": false,
        "$path": "DevPackages"
      },

      "Utility": {
        "$ignoreUnknownInstances": false,
        "$path":"src/Utility"
      },

      "Synced": {
        "$ignoreUnknownInstances": false,
        "$path": "src/General/Shared"
      },

      "Faction_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/FactionSystem/Faction_Framework"
      },

      "Aware_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/AwareSystem/Aware_Framework"
      },

      "SPH_Framework": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/WeaponSystem/SPH_Framework"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,

      "Synced": {
        "$ignoreUnknownInstances": false,
        "$path": "src/General/Server"
      },

      "Faction_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/FactionSystem/Faction_Server"
      },

      "SPH_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/WeaponSystem/SPH_Server"
      },

      "Class_RadioMod": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/Class_RadioMod"
      },

      "Aware_Server": {
        "$ignoreUnknownInstances": false,
        "$path": "src/Systems/AwareSystem/Aware_Server"
      }

    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$ignoreUnknownInstances": true,
      
      "StarterCharacterScripts": {
        "$className": "StarterCharacterScripts",
        "$ignoreUnknownInstances": true,

        "SPH_Character": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/WeaponSystem/SPH_Character"
        }
      },

      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        
        "Synced": {
          "$ignoreUnknownInstances": false,
          "$path": "src/General/Client"
        },

        "Faction_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/FactionSystem/Faction_Player"
        },

        "SPH_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/WeaponSystem/SPH_Player"
        },

        "Aware_Player": {
          "$ignoreUnknownInstances": false,
          "$path": "src/Systems/AwareSystem/Aware_Player"
        }
      }

      
    }
  }
}