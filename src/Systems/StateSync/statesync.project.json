{
  "name": "state-sync",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "Packages": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../Packages"
      },
      "DevPackages": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../DevPackages"
      },
      "Utility": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../src/Utility"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "Systems": {
        "$className": "Folder",
        "StateSync": {
          "$ignoreUnknownInstances": false,
          "$path": "Server"
        }
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "Systems": {
          "$className": "Folder",
          "StateSync": {
            "$ignoreUnknownInstances": false,
            "$path": "Player"
          }
        }
      }
    }
  }
}
