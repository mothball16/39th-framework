{
  "name": "objective",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "Packages": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../Packages"
      },
      "DevPackages": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../DevPackages"
      },
      "Utility": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../src/Utility"
      },
      "Systems": {
        "$className": "Folder",
        "Objective": {
          "$ignoreUnknownInstances": false,
          "$path": "Shared"
        }
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "Systems": {
        "$className": "Folder",
        "Objective": {
          "$ignoreUnknownInstances": false,
          "$path": "Server"
        }
      }
    }
  }
}
