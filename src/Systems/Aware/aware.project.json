{
  "name": "aware",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "Packages": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../Packages"
      },
      "DevPackages": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../DevPackages"
      },
      "Utility": {
        "$ignoreUnknownInstances": false,
        "$path": "../../../src/Utility"
      },
      "Systems": {
        "$className": "Folder",
        "Aware": {
          "$ignoreUnknownInstances": false,
          "$path": "Shared"
        },
        "StateSync": {
          "$ignoreUnknownInstances": false,
          "$path": "../StateSync/Shared"
        }
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "Systems": {
        "$className": "Folder",
        "Aware": {
          "$ignoreUnknownInstances": false,
          "$path": "Server"
        },
        "StateSync": {
          "$ignoreUnknownInstances": false,
          "$path": "../StateSync/Server"
        }
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "Systems": {
          "$className": "Folder",
          "Aware": {
            "$ignoreUnknownInstances": false,
            "$path": "Client"
          },
          "StateSync": {
            "$ignoreUnknownInstances": false,
            "$path": "../StateSync/Client"
          }
        }
      }
    }
  }
}
